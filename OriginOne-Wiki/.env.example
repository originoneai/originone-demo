# Copy this file to `.env` and fill only the values you need.
#
# Never commit `.env`.
# The repository uses an LLM runtime as the engine. The shell scripts only
# package prompts, call the runtime, and safely write allowed files.
#
# If you do not have a Code Agent CLI, use manual mode instead:
#   bash scripts/llm_wiki_agent.sh manual ask 00-minimal-raw-wiki-output "raw wiki output 区别是什么"
# Manual mode bundles stage files into a prompt for a normal LLM chat window,
# but it does not automatically edit the repository.

# Optional. If this is empty, scripts/llm_wiki_agent.sh will use Codex CLI when
# `codex` is available in PATH.
#
# The command must read the task prompt from stdin and be able to edit files in
# this repository.
#
# Examples:
# LLM_WIKI_AGENT=codex -a never exec --sandbox workspace-write -C . -
# LLM_WIKI_AGENT=claude -p --permission-mode acceptEdits
# LLM_WIKI_AGENT=gemini --approval-mode auto_edit --prompt "Run this LLM-Wiki task"
LLM_WIKI_AGENT=

# API keys are not stored in this repository.
# You only need these when your chosen Agent/runtime uses API-key auth.
# If you use an already logged-in CLI, such as Codex CLI / Claude Code /
# Gemini CLI, these may stay empty.
# API keys alone do not make the shell script a full Code Agent. Use the API
# runner below for controlled file writes, or use manual mode for chat windows.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Layer 2: OpenAI-compatible API runner.
#
# This is for users who do not have a Code Agent CLI but do have an API key.
# It calls a Chat Completions-compatible endpoint, asks the model to return
# file-level JSON, then safely writes only allowed wiki/output Markdown files.
#
# DeepSeek example:
# LLM_WIKI_API_BASE_URL=https://api.deepseek.com
# LLM_WIKI_API_MODEL=deepseek-v4-flash
# DEEPSEEK_API_KEY=你的_deepseek_key
#
# OpenAI-compatible providers usually work by changing base_url, model, and key.
LLM_WIKI_API_BASE_URL=https://api.deepseek.com
LLM_WIKI_API_MODEL=deepseek-v4-flash
LLM_WIKI_API_KEY=
DEEPSEEK_API_KEY=
LLM_WIKI_API_MAX_TOKENS=8192
LLM_WIKI_API_TEMPERATURE=0.2
